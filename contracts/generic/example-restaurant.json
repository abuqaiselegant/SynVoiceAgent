  "services": [
    { "key": "lunch",  "name": "Lunch reservation",  "duration_minutes": 60, "booking_system_ref": "lunch" },
    { "key": "dinner", "name": "Dinner reservation", "duration_minutes": 90, "booking_system_ref": "dinner" }
  ],

  "customer_identity": ["phone"],

  "booking_fields": [
