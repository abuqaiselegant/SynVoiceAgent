    "wednesday": { "open": "12:00", "close": "22:00", "breaks": [ { "start": "15:00", "end": "17:00" } ] },
    "thursday":  { "open": "12:00", "close": "22:00", "breaks": [ { "start": "15:00", "end": "17:00" } ] },
    "friday":    { "open": "12:00", "close": "23:00", "breaks": [ { "start": "15:00", "end": "17:00" } ] },
    "saturday":  { "open": "12:00", "close": "23:00", "breaks": [] },
    "sunday":    { "open": "12:00", "close": "20:00", "breaks": [] }
  },

  "resources": [
    { "id": "table_2a", "name": "Table 2", "label": "Window table", "service_keys": ["lunch", "dinner"], "capacity": 2 },
    { "id": "table_4a", "name": "Table 4", "label": "Indoor table", "service_keys": ["lunch", "dinner"], "capacity": 4 },
    { "id": "table_6a", "name": "Table 6", "label": "Patio table",  "service_keys": ["lunch", "dinner"], "capacity": 6 }
