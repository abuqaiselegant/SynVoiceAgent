    { "key": "dietary_note", "label": "dietary requirements", "type": "text",   "required": false }
  ],

  "faq": [
    { "key": "parking",  "question": "Where can I park?",       "answer": "Trinity Square car park is a 3 minute walk away." },
    { "key": "dietary",  "question": "Do you cater for vegans?", "answer": "Yes, we have a full vegan menu — just let us know when you book." }
  ],

  "escalation": {
    "transfer_number": "+441159876544",
    "always_escalate": ["large_party", "complaint"],
    "take_message_when_unreachable": true
  },

  "sms": {
    "sender_name": "OliveTree",
    "templates": {
      "booking_confirmation": "Hi {{customer_name}}, your table is booked for {{date}} at {{time}}. We look forward to seeing you at The Olive Tree.",
      "cancellation": "Hi {{customer_name}}, your reservation on {{date}} at {{time}} has been cancelled.",
      "reschedule": "Hi {{customer_name}}, your reservation is now {{date}} at {{time}}. The Olive Tree."
    }
  }
